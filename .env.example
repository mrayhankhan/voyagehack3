# ── TBO Destination Weddings — Environment Variables ──
# Copy to server/.env and fill in values.

SERVER_PORT=3001
DATABASE_URL=postgresql://postgres:pass@localhost:5432/tbo

# Amadeus Self-Service API (free tier)
AMA_CLIENT_ID=your_amadeus_client_id
AMA_CLIENT_SECRET=your_amadeus_client_secret

# JWT
JWT_SECRET=change-me-to-a-random-string

# Optional
SENTRY_DSN=
NODE_ENV=development
